{
  "name": "rmsoft-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "for i in $(seq 1 15); do lsof -ti :3001 | xargs kill 2>/dev/null; lsof -ti :3001 >/dev/null 2>&1 || exit 0; sleep 0.3; done; lsof -ti :3001 | xargs kill -9 2>/dev/null; true",
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}
